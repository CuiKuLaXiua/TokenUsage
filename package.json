{
  "name": "token-usage",
  "version": "1.0.0",
  "description": "桌面端模型token用量及额度展示工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "generate-icons": "node scripts/generate-icons.mjs",
    "dev": "npm run build:electron && node scripts/dev.mjs",
    "build": "npm run generate-icons && npm run build:electron && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run generate-icons && npm run build:electron && vite build && electron .",
    "electron:build": "npm run generate-icons && npm run build:electron && vite build && electron-builder --config electron-builder.yml",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "postinstall": "patch-package"
  },
  "keywords": [
    "electron",
    "vue3",
    "typescript",
    "token-usage",
    "ai-models"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/utils": "^2.0.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.2",
    "patch-package": "^8.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.0.10",
    "vue-tsc": "^1.8.25",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "dotenv": "^17.4.2",
    "echarts": "^6.1.0",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.3.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.2.5",
    "vuedraggable": "^4.1.0"
  }
}
